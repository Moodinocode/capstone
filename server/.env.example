PORT=5001
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGIN=*

# ── observability ────────────────────────────────────────────────
LOG_LEVEL=info

# ── voting integrity ─────────────────────────────────────────────
# When true, /api/votes requires a server-issued vote token from /api/votes/init.
REQUIRE_VOTE_TOKEN=false
# Independent secret for the HMAC. Falls back to JWT_SECRET if unset.
VOTE_TOKEN_SECRET=

# ── AI insights ──────────────────────────────────────────────────
# Leave ANTHROPIC_API_KEY blank to use the deterministic stub.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ENABLE_AI_INSIGHTS=true
